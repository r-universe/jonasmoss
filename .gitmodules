[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "kdensity"]
	path = kdensity
	url = https://github.com/jonasmoss/kdensity
[submodule "nakagami"]
	path = nakagami
	url = https://github.com/jonasmoss/nakagami
[submodule "publipha"]
	path = publipha
	url = https://github.com/jonasmoss/publipha
[submodule "semTests"]
	path = semTests
	url = https://github.com/jonasmoss/semtests
[submodule "univariateML"]
	path = univariateML
	url = https://github.com/jonasmoss/univariateml
